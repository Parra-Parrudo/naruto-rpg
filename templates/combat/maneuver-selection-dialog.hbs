<div class="nrpg-maneuver-selection">
  <header class="nrpg-maneuver-selection-header">
    <h2>{{localize "NARUTO_RPG.Combat.SelectManeuverTitle"}}</h2>
    {{#if currentSelection}}
    <div class="nrpg-current-selection">
      <span class="nrpg-current-label">{{localize "NARUTO_RPG.Combat.CurrentSelection"}}:</span>
      <span class="nrpg-current-name">{{currentSelection.name}}</span>
    </div>
    {{/if}}
  </header>

  {{#if hasManeuvers}}
  <div class="nrpg-maneuver-list">
    {{#each maneuvers as |maneuver|}}
    <div class="nrpg-maneuver-card {{#unless maneuver.canAfford}}nrpg-cannot-afford{{/unless}} {{#if (eq maneuver.id @root.currentSelectionId)}}nrpg-selected{{/if}}"
         data-maneuver-id="{{maneuver.id}}">

      {{!-- Main Row - Clickable to select --}}
      <div class="nrpg-maneuver-row" data-action="selectManeuver" data-maneuver-id="{{maneuver.id}}">
        <span class="nrpg-maneuver-name">{{maneuver.name}}</span>
        <span class="nrpg-maneuver-category">{{maneuver.category}}</span>

        <div class="nrpg-maneuver-stats-inline">
          <span class="nrpg-stat-inline {{#if maneuver.hasSpeedModifiers}}nrpg-stat-modified{{/if}}" title="{{localize 'NARUTO_RPG.Combat.Speed'}}{{#if maneuver.hasSpeedModifiers}} ({{localize 'NARUTO_RPG.ActiveEffects.modifiedManeuverStat'}}){{/if}}">
            <i class="fas fa-bolt"></i> {{maneuver.calculatedSpeed}}
            {{#if maneuver.hasSpeedModifiers}}<i class="fas fa-magic nrpg-effect-indicator"></i>{{/if}}
          </span>
          <span class="nrpg-stat-inline {{#if maneuver.hasDamageModifiers}}nrpg-stat-modified{{/if}}" title="{{localize 'NARUTO_RPG.Combat.Damage'}}{{#if maneuver.hasDamageModifiers}} ({{localize 'NARUTO_RPG.ActiveEffects.modifiedManeuverStat'}}){{/if}}">
            <i class="fas fa-fist-raised"></i> {{maneuver.calculatedDamage}}
            {{#if maneuver.hasDamageModifiers}}<i class="fas fa-magic nrpg-effect-indicator"></i>{{/if}}
          </span>
          <span class="nrpg-stat-inline {{#if maneuver.hasMovementModifiers}}nrpg-stat-modified{{/if}}" title="{{localize 'NARUTO_RPG.Combat.Movement'}}{{#if maneuver.hasMovementModifiers}} ({{localize 'NARUTO_RPG.ActiveEffects.modifiedManeuverStat'}}){{/if}}">
            <i class="fas fa-running"></i> {{maneuver.calculatedMovement}}
            {{#if maneuver.hasMovementModifiers}}<i class="fas fa-magic nrpg-effect-indicator"></i>{{/if}}
          </span>
        </div>

        {{#if maneuver.chiCost}}
        <span class="nrpg-cost-badge nrpg-cost-chi" title="{{localize 'NARUTO_RPG.Resources.chi'}}">
          <i class="fas fa-yin-yang"></i> {{maneuver.chiCost}}
        </span>
        {{/if}}
        {{#if maneuver.willpowerCost}}
        <span class="nrpg-cost-badge nrpg-cost-willpower" title="{{localize 'NARUTO_RPG.Resources.willpower'}}">
          <i class="fas fa-brain"></i> {{maneuver.willpowerCost}}
        </span>
        {{/if}}

        {{#if (eq maneuver.id @root.currentSelectionId)}}
        <span class="nrpg-selected-check"><i class="fas fa-check-circle"></i></span>
        {{/if}}

        {{#if (or maneuver.notes maneuver.ruleSummary)}}
        <span class="nrpg-maneuver-expand" data-action="toggleNotes"><i class="fas fa-chevron-down"></i></span>
        {{/if}}
      </div>

      {{!-- Expandable Notes Section --}}
      {{#if (or maneuver.notes maneuver.ruleSummary)}}
      <div class="nrpg-maneuver-notes collapsed">
        <div class="nrpg-notes-content">
          {{#if maneuver.notes}}
          <p>{{maneuver.notes}}</p>
          {{/if}}
          {{#if maneuver.ruleSummary}}
          <p class="nrpg-rule-summary">{{maneuver.ruleSummary}}</p>
          {{/if}}
        </div>
      </div>
      {{/if}}

      {{#unless maneuver.canAfford}}
      <div class="nrpg-cannot-afford-overlay">
        <span>{{localize "NARUTO_RPG.Combat.CannotAfford"}}</span>
      </div>
      {{/unless}}
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="nrpg-no-maneuvers">
    <p>{{localize "NARUTO_RPG.Combat.NoManeuversAvailable"}}</p>
  </div>
  {{/if}}
</div>
