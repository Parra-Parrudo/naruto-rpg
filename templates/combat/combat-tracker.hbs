<section class="combat-tracker nrpg-combat-tracker" id="combat-tracker">
  {{#if combats}}
  <header class="combat-tracker-header">
    {{#if sfCombat}}
    <div class="nrpg-phase-indicator nrpg-phase-{{sfCombat.phase}}">
      <i class="fas fa-circle"></i>
      <span class="nrpg-phase-label">{{sfCombat.phaseLabel}}</span>
    </div>
    {{/if}}

    <nav class="encounters flexrow" aria-label="{{localize 'COMBAT.NavLabel'}}">
      {{#if combats.length}}
      <button type="button" class="combat-cycle" data-action="previousCombat" data-tooltip="COMBAT.EncounterPrevious"
        aria-label="{{localize 'COMBAT.EncounterPrevious'}}" {{disabled (eq combatCount 1)}}>
        <i class="fas fa-caret-left"></i>
      </button>
      <span class="encounter-count">
        {{localize "COMBAT.Encounter"}} {{combatIndex}} / {{combatCount}}
      </span>
      <button type="button" class="combat-cycle" data-action="nextCombat" data-tooltip="COMBAT.EncounterNext"
        aria-label="{{localize 'COMBAT.EncounterNext'}}" {{disabled (eq combatCount 1)}}>
        <i class="fas fa-caret-right"></i>
      </button>
      {{/if}}
    </nav>
  </header>
  {{/if}}

  {{#if viewed}}
  <section class="combat-tracker-content">
    {{!-- Round Display --}}
    <div class="nrpg-round-display">
      <span class="nrpg-round-label">{{localize "COMBAT.Round"}}</span>
      <span class="nrpg-round-number">{{viewed.round}}</span>
    </div>

    {{!-- GM Controls --}}
    {{#if sfCombat.isGM}}
    <div class="nrpg-gm-controls">
      <button type="button" class="nrpg-control-btn nrpg-return-cards" data-action="returnCards" data-tooltip="{{localize 'NARUTO_RPG.Cards.returnBtnHint'}}">
        <i class="fas fa-undo"></i>
        {{localize "NARUTO_RPG.Cards.returnBtn"}}
      </button>
      {{#if sfCombat.isSetup}}
      <button type="button" class="nrpg-control-btn nrpg-start-turn" data-action="startTurn">
        <i class="fas fa-play"></i>
        {{localize "NARUTO_RPG.Combat.StartTurn"}}
      </button>
      {{/if}}

      {{#if sfCombat.isSelection}}
      <button type="button" class="nrpg-control-btn nrpg-start-execution" data-action="startExecution"
        {{disabled (not sfCombat.allSelectionsComplete)}}>
        <i class="fas fa-bolt"></i>
        {{localize "NARUTO_RPG.Combat.StartExecution"}}
      </button>
      {{/if}}

      {{#if sfCombat.isExecution}}
        {{#if sfCombat.allActionsComplete}}
        <button type="button" class="nrpg-control-btn nrpg-next-turn" data-action="nextTurn">
          <i class="fas fa-forward"></i>
          {{localize "NARUTO_RPG.Combat.NextTurn"}}
        </button>
        {{else}}
        <button type="button" class="nrpg-control-btn nrpg-complete-action" data-action="completeAction"
          {{disabled (not sfCombat.currentActingId)}}>
          <i class="fas fa-check"></i>
          {{localize "NARUTO_RPG.Combat.CompleteAction"}}
        </button>
        {{/if}}
      {{/if}}
    </div>
    {{/if}}

    {{!-- Combatant List --}}
    <ol class="combatant-list">
      {{#each turns as |turn|}}
      {{!-- Show hidden combatants only to GM --}}
      {{#unless (and turn.hidden (not @root.sfCombat.isGM))}}
      <li class="combatant {{#if turn.sf.isActing}}nrpg-acting{{/if}} {{#if turn.sf.isCompleted}}nrpg-completed{{/if}} {{#if turn.sf.isInterrupted}}nrpg-interrupted{{/if}} {{#if turn.hidden}}nrpg-hidden{{/if}} {{#if turn.defeated}}defeated{{/if}}"
          data-combatant-id="{{turn.id}}"
          data-token-id="{{turn.tokenId}}">

        {{!-- Combatant Image --}}
        <div class="combatant-image">
          <img src="{{turn.img}}" alt="{{turn.name}}" />
          {{#if turn.sf.isActing}}
          <div class="nrpg-acting-indicator">
            <i class="fas fa-bolt"></i>
          </div>
          {{/if}}
        </div>

        {{!-- Combatant Info --}}
        <div class="combatant-info">
          <h4 class="combatant-name">
            {{turn.name}}
            {{!-- Only show speed during execution phase --}}
            {{#if @root.sfCombat.isExecution}}
            {{#if turn.sf.speed}}
            <span class="nrpg-speed-badge" data-tooltip="{{localize 'NARUTO_RPG.Combat.Speed'}}">
              <i class="fas fa-bolt"></i> {{turn.sf.speed}}
            </span>
            {{/if}}
            {{/if}}
          </h4>

          <div class="combatant-status">
            <i class="{{turn.sf.statusIcon}}" data-tooltip="{{turn.sf.statusLabel}}"></i>
            <span class="nrpg-status-text">{{turn.sf.statusLabel}}</span>
          </div>

          {{!-- Show selected maneuver to owner during execution phase --}}
          {{#if @root.sfCombat.isExecution}}
          {{#if turn.sf.selectedManeuver}}
          {{#if turn.sf.isOwner}}
          <div class="nrpg-selected-maneuver">
            <span class="nrpg-maneuver-name {{#if turn.sf.maneuverRevealed}}nrpg-revealed{{else}}nrpg-hidden{{/if}}">
              <i class="fas fa-fist-raised"></i> {{turn.sf.selectedManeuver.name}}
            </span>
          </div>
          {{else}}
          {{#if turn.sf.maneuverRevealed}}
          <div class="nrpg-selected-maneuver">
            <span class="nrpg-maneuver-name nrpg-revealed">
              <i class="fas fa-fist-raised"></i> {{turn.sf.selectedManeuver.name}}
            </span>
          </div>
          {{/if}}
          {{/if}}
          {{/if}}
          {{/if}}
        </div>

        {{!-- Combatant Controls --}}
        <div class="combatant-controls nrpg-combatant-controls">
          {{!-- Selection Phase: Maneuver Selection Button --}}
          {{#if turn.sf.showManeuverButton}}
          <button type="button" class="nrpg-maneuver-btn {{#if turn.sf.isReady}}nrpg-ready{{/if}}"
                  data-action="openManeuverSelection"
                  data-tooltip="{{#if turn.sf.isReady}}{{localize 'NARUTO_RPG.Combat.ChangeManeuver'}}{{else}}{{localize 'NARUTO_RPG.Combat.SelectManeuver'}}{{/if}}">
            <i class="fas {{#if turn.sf.isReady}}fa-check{{else}}fa-fist-raised{{/if}}"></i>
          </button>
          {{/if}}

          {{!-- Execution Phase: Reveal Maneuver Button (for acting combatant owner, not revealed yet) --}}
          {{#if turn.sf.isActing}}
          {{#if turn.sf.isOwner}}
          {{#unless turn.sf.maneuverRevealed}}
          <button type="button" class="nrpg-reveal-btn" data-action="revealManeuver"
                  data-tooltip="{{localize 'NARUTO_RPG.Combat.RevealManeuver'}}">
            <i class="fas fa-id-card"></i>
          </button>
          {{/unless}}
          <button type="button" class="nrpg-turn-dialog-btn" data-action="openTurnDialog"
                  data-tooltip="{{localize 'NARUTO_RPG.Combat.OpenTurnDialog'}}">
            <i class="fas fa-window-restore"></i>
          </button>
          {{/if}}
          {{/if}}

          {{!-- Execution Phase: Interrupt Button --}}
          {{#if turn.sf.canInterrupt}}
          <button type="button" class="nrpg-interrupt-btn" data-action="interrupt"
                  data-tooltip="{{localize 'NARUTO_RPG.Combat.Interrupt'}}">
            <i class="fas fa-hand-paper"></i>
          </button>
          {{/if}}

          {{!-- Standard Controls --}}
          {{#if @root.sfCombat.isGM}}
          <button type="button" class="combatant-control" data-action="toggleHidden"
                  data-tooltip="{{#if turn.hidden}}COMBAT.RevealCombatant{{else}}COMBAT.HideCombatant{{/if}}">
            <i class="fas {{#if turn.hidden}}fa-eye-slash{{else}}fa-eye{{/if}}"></i>
          </button>
          <button type="button" class="combatant-control" data-action="toggleDefeatedStatus"
                  data-tooltip="{{#if turn.defeated}}COMBAT.MarkAlive{{else}}COMBAT.MarkDefeated{{/if}}">
            <i class="fas {{#if turn.defeated}}fa-skull{{else}}fa-heart{{/if}}"></i>
          </button>
          {{/if}}
        </div>
      </li>
      {{/unless}}
      {{/each}}
    </ol>
  </section>

  {{else}}
  {{!-- No Active Combat --}}
  <section class="combat-tracker-content no-combat">
    <p class="no-combat-message">{{localize "COMBAT.None"}}</p>
    {{#if sfCombat.isGM}}
    <button type="button" class="create-combat" data-action="createCombat">
      <i class="fas fa-plus"></i>
      {{localize "COMBAT.Create"}}
    </button>
    {{/if}}
  </section>
  {{/if}}

  {{!-- Footer Controls --}}
  {{#if viewed}}
  <footer class="combat-tracker-footer">
    {{#if sfCombat.isGM}}
    <button type="button" class="combat-control" data-action="endCombat" data-tooltip="{{localize 'COMBAT.End'}}">
      <i class="fas fa-times"></i>
    </button>
    <button type="button" class="combat-control" data-action="resetAll" data-tooltip="{{localize 'NARUTO_RPG.Combat.ResetSelections'}}">
      <i class="fas fa-undo"></i>
    </button>
    {{/if}}
  </footer>
  {{/if}}
</section>
